{
  "name": "@itchyny/s3-cache-action",
  "version": "1.1.6",
  "description": "Cache files to Amazon S3",
  "author": "itchyny <itchyny@cybozu.co.jp>",
  "license": "MIT",
  "homepage": "https://github.com/itchyny/s3-cache-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itchyny/s3-cache-action.git"
  },
  "bugs": {
    "url": "https://github.com/itchyny/s3-cache-action/issues"
  },
  "type": "module",
  "main": "lib/cache.js",
  "types": "lib/cache.d.ts",
  "files": [
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "s3",
    "cache",
    "actions"
  ],
  "scripts": {
    "build": "ncc build -m -o dist/restore src/restore.ts && ncc build -m -o dist/save src/save.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings=ExperimentalWarning' jest --runInBand",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepublishOnly": "tsc --declaration"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/glob": "^0.7.0",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/lib-storage": "^3.1057.0",
    "tar": "^7.5.16",
    "tmp": "^0.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/tmp": "^0.2.6",
    "@vercel/ncc": "^0.38.4",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
